930\u0941\u0923\u0940\u0902\u0938\u093e\u0920\u0940 \u090f\u0915\u0932\u0935\u094d\u092f \u092b\u093e\u0909\u0902\u0921\u0947\u0936\u0928\u0928\u0947 \u0906\u092f\u094b\u091c\u093f\u0924 \u0915\u0947\u0932\u0947\u0932\u093e \u0928\u094b\u0915\u0930\u0940 \u092e\u0939\u094b\u0924\u094d\u0938\u0935 \u0939\u093e \u092a\u0930\u093f\u0935\u0930\u094d\u0924\u0928\u093e\u091a\u0940 \u0928\u0935\u0940 \u0926\u093f\u0936\u093e \u0920\u0930\u0932\u093e. \u092e\u0939\u093e\u0921, \u0905\u0932\u093f\u092c\u093e\u0917, \u0930\u094b\u0939\u093e, \u092e\u0941\u0930\u0941\u0921, \u092a\u0928\u0935\u0947\u0932, \u0916\u094b\u092a\u094b\u0932\u0940 \u092f\u0947\u0925\u0940\u0932 \u0909\u092e\u0947\u0926\u0935\u093e\u0930\u093e\u0902\u0938\u093e\u0920\u0940 \u096b\u0966 \u092a\u0947\u0915\u094d\u0937\u093e \u0905\u0927\u093f\u0915 \u0928\u093e\u092e\u093e\u0902\u0915\u093f\u0924 \u0915\u0902\u092a\u0928\u094d\u092f\u093e\u0902\u0928\u093e \u090f\u0915\u093e\u091a \u0935\u094d\u092f\u093e\u0938\u092a\u0940\u0920\u093e\u0935\u0930 \u0906\u0923\u0942\u0928 \u0939\u091c\u093e\u0930\u094b \u0924\u0930\u0941\u0923\u093e\u0902\u0928\u093e \u0930\u094b\u091c\u0917\u093e\u0930\u093e\u091a\u094d\u092f\u093e \u0938\u0902\u0927\u0940 \u0909\u092a\u0932\u092c\u094d\u0927 \u0915\u0930\u0942\u0928 \u0926\u0947\u0923\u094d\u092f\u093e\u0924 \u0906\u0932\u094d\u092f\u093e. \u0928\u0935\u0940 \u092e\u0941\u0902\u092c\u0908, \u0930\u0938\u093e\u092f\u0928\u0940, \u0916\u094b\u092a\u094b\u0932\u0940 \u0906\u0923\u093f \u0905\u0932\u093f\u092c\u093e\u0917\u092e\u0927\u0940\u0932 \u0909\u0926\u094d\u092f\u094b\u0917\u093e\u0902\u0928\u0940 \u092e\u094b\u0920\u094d\u092f\u093e \u0909\u0924\u094d\u0938\u093e\u0939\u093e\u0928\u0947 \u0938\u0939\u092d\u093e\u0917 \u0928\u094b\u0902\u0926\u0935\u0932\u093e. \u092e\u093e\u0928\u0928\u0940\u092f \u0928\u0947\u0924\u094d\u092f\u093e\u0902\u091a\u094d\u092f\u093e \u0939\u0938\u094d\u0924\u0947 \u0938\u0928\u094d\u092e\u093e\u0928\u093f\u0924 \u0939\u094b\u0924, \u